# Copy this file to .env and fill in your values

PORT=3001

# Gmail or other SMTP service
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com

# For Gmail: generate an App Password at https://myaccount.google.com/apppasswords
# (requires 2FA to be enabled on your Google account)
EMAIL_PASS=your_app_password_here

# Email address that receives the contact form messages (defaults to EMAIL_USER)
RECIPIENT_EMAIL=darrendexterthio@gmail.com

# Your deployed frontend URL (e.g. https://darrencasper.com)
# Set to * during development to allow all origins
ALLOWED_ORIGIN=https://your-portfolio-domain.com
